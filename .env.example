# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Base URL of the app (http://localhost:3000 in dev, https://... in prod)
NEXTAUTH_URL="http://localhost:3000"

# --- Resend (magic-link email + reminders) ---
# NOTE: to email anyone other than your own Resend account address you must
# verify a sending domain in Resend and add its DNS records.
AUTH_RESEND_KEY=""
EMAIL_FROM="Bolão do Barão <bolao@yourdomain.com>"

# --- football-data.org (free tier API token) ---
FOOTBALL_DATA_TOKEN=""
# WC 2026 competition id on football-data.org (verify; "WC" code or numeric id)
FOOTBALL_DATA_COMPETITION="WC"

# --- Cron protection (shared secret for /api/cron/* routes) ---
CRON_SECRET=""

# --- Admin bootstrap (comma-separated emails granted admin on first login) ---
ADMIN_EMAILS="admin@example.com"
